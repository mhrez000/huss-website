# --- Email (booking + contact notifications) ---
# Create a key at https://resend.com — without it, submissions are logged
# to the server console and the forms still confirm to the user.
RESEND_API_KEY=

# Where admin notifications are sent
BOOKING_NOTIFY_EMAIL=hello@luxevisuals.com.au

# Verified sender address for outgoing mail
EMAIL_FROM="LuxeVisuals <bookings@luxevisuals.com.au>"

# --- Bookings database (live availability) ---
# Create a free Supabase project, run supabase/bookings.sql in its SQL
# editor, then copy these from Project Settings -> API. Without them,
# bookings persist to a local .data/bookings.json file — fine for dev,
# NOT for serverless production (the filesystem is ephemeral there).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
